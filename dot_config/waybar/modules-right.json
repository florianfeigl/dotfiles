{

  "bluetooth": {
    "format": " {status}",
    "on-click": "blueman-manager"
  },

  "backlight": {
    "justify": "center",
    "min-length": 6,
    "format": "{icon} {percent}",
    "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
  },

  "custom/volume": {
    "justify": "center",
    "min-length": 6,
    "format": "{icon} {output}",
    "format-icons": {
      "100": "",
      "75": "",
      "50": "",
      "25": "",
      "0": ""
    },
    "exec": "~/.config/waybar/volume.sh",
    "exec-on-event": true,
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol-qt"
  },

  "network": {
    "justify": "center",
    "min-length": 6,
    "format-wifi": "{icon} {essid}",
    "format-ethernet": "{icon} {ipaddr}/{cidr}",
    "format-icons": {
      "wifi": "ΎΘτ",
      "ethernet": "ΎηΨ",
      "disconnected": "έγι"
    },
    "tooltip-format": "{icon} {ifname} via {gwaddr} ",
    "format-linked": "{icon} {ifname} (No IP) ",
    "format-disconnected": "{icon}",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },

  "tray": {
    "justify": "center",
    "min-length": 20,
    "icon-size": 24,
    "spacing": 8
  },

  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "\uf0f3",
      "none": "\uf0f3",
      "dnd-notification": "\uf1f6",
      "dnd-none": "\uf1f6",
      "inhibited-notification": "\uf0f3",
      "inhibited-none": "\uf0f3",
      "dnd-inhibited-notification": "\uf1f6",
      "dnd-inhibited-none": "\uf1f6"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ΎΔπ",
      "performance": "ΎΔπ",
      "balanced": "ΎΚΟ",
      "power-saver": "ΎΒυ"
    }
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "≤░Ζ╢",
      "deactivated": "≤░Τ▓"
    }
  },

  "custom/power": {
    "format": "≤░Ρξ",
    "tooltip": false,
    "on-click": "~/.config/waybar/power_menu.sh"
  }

}
