{
  "custom/appmenu": {
    "min-length": 3,
    "format": "ґ░╗А",
    "rotate": 0,
    "on-click": "wofi --show drun"
  },

  "clock": {
    "format": "яАЧ {:%H:%M:%S}",
    "format-alt": "яБ│ {:%A,%d.%B яАЧ %R}",
    "interval": 1,
    "justify": "left",
    "align": 0,
    "min-length": 11,
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar-weeks-pos": "right",
    "today-format": "<span color='#ed8796'><b><u>{}</u></b></span>", // Catppuccin Red
    "format-calendar": "<span color='#91d7e3'><b>{}</b></span>",     // Catppuccin Sky
    "format-calendar-weeks": "<span color='#c6a0f6'><b>W{:%V}</b></span>", // Catppuccin Mauve
    "format-calendar-weekdays": "<span color='#a5adcb'><b>{}</b></span>", // Catppuccin Subtext0
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#91d7e3'><b>{}</b></span>",      // Sky
        "days": "<span color='#cad3f5'><b>{}</b></span>",        // Text
        "weeks": "<span color='#c6a0f6'><b>W{}</b></span>",      // Mauve
        "weekdays": "<span color='#a5adcb'><b>{}</b></span>",    // Subtext0
        "today": "<span color='#ed8796'><b><u>{}</u></b></span>" // Red
      },
      "actions": {
        "on-click": "mode",
        "on-click-right": "toggle"
      }
    }
  },

  "cpu": {
    "states": {
      "good": 70,
      "warning": 75,
      "critical": 90
    },
    "format": "яЛЫ {usage}",
    "justify": "left",
    "align": 0,
    "min-length": 5,
    "tooltip": true
  },

  "memory": {
    "states": {
      "warning": 75, 
      "critical": 90
    },
    "justify": "left",
    "align": 0,
    "min-length": 5,
    "format": "яГЙ {}"
  },

  "disk": {
    "path": "/",
    "interval": 30,
    "justify": "left",
    "align": 0,
    "min-length": 5,
    "states": {
      "warning": 80,
      "critical": 90
    },
    "format": "яЗА {percentage_used}",
    "format-warning": "яЗА {percentage_used}",
    "format-critical": "яЗА {percentage_used}"
  },

  "temperature": {
    "states": {
      "warning": 75,
      "critical": 85
    },
    "justify": "left",
    "align": 0,
    "min-length": 5,
    "format": "{icon} {temperatureC}",
    "format-warning": "{icon} {temperatureC}",
    "format-critical": "{icon} {temperatureC}",
    "format-icons": ["яЭл", "яЛЙ", "яЭй"]
  },

  "battery": {
    "bat": "BAT0",
    "states": {
      "good": 60,
      "warning": 30,
      "critical": 15
    },
    "justify": "left",
    "align": 0,
    "min-length": 5,
    "format": "{icon} {capacity}",
    "format-full": "{icon} {capacity}",
    "format-charging": "яЧз {capacity}",
    "format-plugged": "яЗж {capacity}",
    "format-alt": "{icon} {time}",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },

  "battery#bat2": {
    "bat": "BAT1",
    "states": {
      "good": 60,
      "warning": 30,
      "critical": 15
    },
    "justify": "left",
    "align": 0,
    "min-length": 5,
    "format": "{icon} {capacity}",
    "format-charging": "яЧз {capacity}",
    "format-plugged": "яЗж {capacity}",
    "format-alt": "{icon} {time}",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  }
}
